# Production environment variables (example - do NOT commit secrets)

# ClickHouse
NTI_CH_HOST=clickhouse.prod.svc.cluster.local
NTI_CH_PORT=8123
NTI_CH_USER=clickhouse_user
NTI_CH_PASSWORD=__CLICKHOUSE_PASSWORD__

# Kafka
NTI_KAFKA_BROKERS=kafka-0.kafka-headless.prod.svc.cluster.local:9093
NTI_KAFKA_TOPIC=network-telemetry-avro
NTI_KAFKA_TLS=true
NTI_KAFKA_TLS_INSECURE=false
NTI_KAFKA_SASL_USER=__KAFKA_SASL_USER__
NTI_KAFKA_SASL_PASS=__KAFKA_SASL_PASS__

# Agent
NTI_PUBLISHER=kafka
NTI_EDGE_INTERVAL_SEC=1

# API
API_HOST=0.0.0.0
API_PORT=8000

# Environment
ENVIRONMENT=production
