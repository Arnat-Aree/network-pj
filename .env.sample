# Sample environment variables (DO NOT store secrets in VCS)

# ClickHouse
NTI_CH_HOST=localhost
NTI_CH_PORT=8123
NTI_CH_USER=default
# Set a strong password in production via secret management
NTI_CH_PASSWORD=NTI_Secure_2026

# Kafka
NTI_KAFKA_BROKERS=localhost:9092
NTI_KAFKA_TOPIC=network-telemetry-avro

# Edge agent
NTI_EDGE_INTERVAL_SEC=1

# API
API_HOST=0.0.0.0
API_PORT=8000

# Deployment
ENVIRONMENT=development

# Observability
OTEL_COLLECTOR=host.docker.internal:4317
NTI_KAFKA_TLS=true
NTI_KAFKA_TLS_INSECURE=true
NTI_KAFKA_SASL_USER=admin
NTI_KAFKA_SASL_PASS=admin-secret
