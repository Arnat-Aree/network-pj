# Sample environment variables (DO NOT store secrets in VCS)

# ClickHouse
NTA_CH_HOST=localhost
NTA_CH_PORT=8123
NTA_CH_USER=default
# Set a strong password in production via secret management
NTA_CH_PASSWORD=lab

# Kafka
NTA_KAFKA_BROKERS=localhost:9092
NTA_KAFKA_TOPIC=network-telemetry-avro

# Edge agent
NTA_EDGE_INTERVAL_SEC=1

# API
API_HOST=0.0.0.0
API_PORT=8000

# Deployment
ENVIRONMENT=development

# Observability
OTEL_COLLECTOR=host.docker.internal:4317
NTA_KAFKA_TLS=true
NTA_KAFKA_TLS_INSECURE=true
NTA_KAFKA_SASL_USER=admin
NTA_KAFKA_SASL_PASS=admin-secret
